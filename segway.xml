<mujoco model="simple_segway_inverted_pendulum">

  <compiler angle="radian"/>
  <option timestep="0.002" gravity="0 0 -9.81" integrator="RK4"/>

  <default>
    <joint damping="0.01" armature="0.001"/>
    <geom friction="1.2 0.01 0.001"/>
  </default>

  <worldbody>
    <light pos="0 0 5" dir="0 0 -1"/>
    <geom name="ground"
          type="plane"
          size="10 10 0.1"
          rgba="0.8 0.8 0.8 1"/>

    <!-- Main Segway body -->
    <body name="segway" pos="0 0 0.25">

      <!-- The whole Segway can move in the x-z plane -->
      <joint name="x_slide" type="slide" axis="1 0 0"/>
      <joint name="body_pitch" type="hinge" axis="0 1 0"/>

      <!-- Wheel visual -->
      <geom name="wheel"
            type="cylinder"
            size="0.18 0.06"
            pos="0 0 0"
            euler="1.5708 0 0"
            mass="0.5"
            rgba="0.02 0.02 0.02 1"/>

      <!-- Upright body -->
      <geom name="body"
            type="box"
            size="0.10 0.06 0.45"
            pos="0 0 0.45"
            mass="1.5"
            rgba="0.1 0.1 0.8 1"/>

      <!-- Handlebar -->
      <geom name="handle"
            type="capsule"
            fromto="0 -0.25 0.85 0 0.25 0.85"
            size="0.025"
            mass="0.1"
            rgba="0.1 0.1 0.1 1"/>

    </body>
  </worldbody>

  <actuator>
    <!-- This applies horizontal force, like the simple cart-pole model -->
    <motor name="drive_motor"
           joint="x_slide"
           gear="1"
           ctrllimited="true"
           ctrlrange="-100 100"/>
  </actuator>

</mujoco>