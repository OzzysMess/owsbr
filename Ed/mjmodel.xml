<mujoco model="simple_segway">
  <compiler angle="radian"/>

  <default>
    <joint damping="0.1"/>
    <geom friction="1 0.1 0.1" density="500"/>
  </default>

  <worldbody>
    <geom name="ground" size="10 10 0.1" type="plane" rgba="0.8 0.8 0.8 1"/>
    <light pos="0 0 4" dir="0 0 -1"/>
    <body name="cart" pos="0 0 0.15">
      <joint name="cart_slide" pos="0 0 0" axis="1 0 0" type="slide"/>
      <geom name="wheel" size="0.15 0.08" quat="0.707105 0.707108 0 0" type="cylinder" rgba="0.1 0.2 0.8 1"/>
      <body name="pendulum">
        <joint name="theta_hinge" pos="0 0 0" axis="0 1 0" damping="0.05"/>
        <geom name="body_rod" size="0.05 0.5" pos="0 0 0.5" quat="0 1 0 0" type="capsule" rgba="0.9 0.1 0.1 1"/>
        <geom name="top_mass" size="0.12" pos="0 0 1" rgba="0.9 0.1 0.1 1"/>
      </body>
    </body>
  </worldbody>

  <actuator>
    <general name="cart_motor" joint="cart_slide" ctrllimited="true" ctrlrange="-50 50"/>
  </actuator>
</mujoco>
